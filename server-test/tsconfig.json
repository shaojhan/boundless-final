{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "#src/*": ["./src/*"],
      "#db-helpers/*": ["./db-helpers/*"],
      "#configs/*": ["./configs/*"],
      "#generated/*": ["./generated/*"]
    }
  },
  "include": ["**/*.ts", "**/*.js", "src/**/*.ts"],
  "exclude": ["node_modules", "generated"]
}
